# Copy this file to .env for local development.
APP_ENV=development
SECRET_KEY=replace-with-a-long-random-value
FLASK_DEBUG=true

# Obtain a key from BALLDONTLIE. Never commit a real key.
BALLDONTLIE_API_KEY=replace-with-your-balldontlie-api-key
SPORTS_API_BASE_URL=https://api.balldontlie.io
SPORTS_API_TIMEOUT_SECONDS=5
SPORTS_API_MAX_RETRIES=3
SPORTS_API_BACKOFF_SECONDS=0.5
SPORTS_API_CACHE_TTL_SECONDS=300
